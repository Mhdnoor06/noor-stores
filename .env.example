# Copy to .env and fill in. The NEXT_PUBLIC_* values are required at build time
# and on Vercel (Project → Settings → Environment Variables).

# Supabase project URL, e.g. https://pfykrfnvfxwyxzbdwheh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key (safe to expose; DB is guarded by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase secret/service-role key — server-side only, NEVER prefix NEXT_PUBLIC.
# Not currently used by the app; leave blank until a server route needs it.
SUPABASE_SECRET_KEY=
